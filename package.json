{
  "name": "fiberscope",
  "private": true,
  "version": "0.1.0",
  "description": "Fiber Network explorer, route diagnostics, and liquidity intelligence infrastructure.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo build",
    "codespaces:demo": "scripts/codespaces-start-demo.sh demo",
    "codespaces:health": "scripts/codespaces-health.sh",
    "codespaces:live": "scripts/codespaces-start-demo.sh live-node",
    "codespaces:start": "scripts/codespaces-start-demo.sh",
    "codespaces:stop": "scripts/codespaces-stop-demo.sh",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "dev": "turbo dev --parallel",
    "dev:demo": "scripts/dev-profile.sh demo",
    "dev:live": "scripts/dev-profile.sh live-node",
    "fiber:testnet": "scripts/start-fiber-testnet-node.sh",
    "format": "prettier --write .",
    "lint": "turbo lint",
    "seed": "tsx prisma/seed.ts",
    "smoke:live": "scripts/smoke-live.sh",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  }
}
