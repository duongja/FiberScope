# FiberScope live-node profile.
# Copy to .env.live-node and edit FIBER_RPC_URLS when using another node.

DATABASE_URL="postgresql://fiberscope:fiberscope@localhost:5432/fiberscope?schema=realnode"
FIBERSCOPE_DB_SCHEMA="realnode"
REDIS_URL="redis://localhost:6379"

# For local pnpm dev, a local Fiber node usually exposes RPC here.
# For full Docker Compose mode on Linux, use http://host.docker.internal:8227 instead.
FIBER_RPC_URLS="http://127.0.0.1:8227"
FIBER_GRAPH_POLL_INTERVAL_SECONDS="300"
FIBERSCOPE_USE_SAMPLE_DATA="false"

CKB_RPC_URL="https://testnet.ckb.dev/rpc"
CKB_INDEXER_URL="https://testnet.ckb.dev/indexer"
CKB_EXPLORER_BASE_URL="https://pudge.explorer.nervos.org"
CKB_ENRICH_INTERVAL_SECONDS="180"

FIBERSCOPE_ENABLE_REACHABILITY_PROBES="false"
FIBERSCOPE_REACHABILITY_PROBE_INTERVAL_SECONDS="300"
FIBERSCOPE_REACHABILITY_TIMEOUT_MS="2500"
FIBERSCOPE_REACHABILITY_PROBE_LIMIT="50"

NEXT_PUBLIC_API_URL="http://localhost:8788"
API_PORT="8788"
WEB_PORT="3000"
