{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm --filter @fiberscope/api... build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm db:generate",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api?__fiberscope_path=/health"
    },
    {
      "source": "/api/:path*",
      "destination": "/api?__fiberscope_api_path=:path*"
    }
  ]
}
